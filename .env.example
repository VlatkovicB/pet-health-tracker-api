PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pet_health_tracker
DB_USER=postgres
DB_PASSWORD=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d

# Email (Resend — https://resend.com)
RESEND_API_KEY=re_your_api_key_here
# Dev: omit EMAIL_FROM to use onboarding@resend.dev (no domain verification needed, sends only to your Resend account email)
# Prod: set to a verified domain address, e.g. Pet Health Tracker <noreply@yourdomain.com>
# EMAIL_FROM=Pet Health Tracker <noreply@yourdomain.com>
GOOGLE_PLACES_API_KEY=google_places_api_key

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Default limits (per user, unless overridden via admin panel)
DEFAULT_MAX_PETS=5
DEFAULT_MAX_VETS=10
DEFAULT_MAX_MEDICATIONS=10
DEFAULT_MAX_NOTES=50
DEFAULT_MAX_STORAGE_BYTES=104857600
DEFAULT_MAX_PLACES_SEARCHES_MONTHLY=10

# OAuth — callback base (must match provider app settings)
API_URL=http://localhost:3000
CLIENT_URL=http://localhost:5173

# Google OAuth (console.developers.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth (developers.facebook.com)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Apple OAuth — requires HTTPS callback URL even in dev (use ngrok or deploy)
# Service ID registered at developer.apple.com
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# Paste PEM key contents inline (replace newlines with \n) or use a file path
APPLE_PRIVATE_KEY=